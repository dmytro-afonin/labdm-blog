# Neon — paste from Neon dashboard (https://console.neon.tech). Server-only; do not use PUBLIC_ prefix.
POSTGRES_URL=

# Resend — server-only values used by newsletter sync and contact webhook verification.
# Sending key (may be send-only). Optional if you only run sync and set RESEND_CONTACTS_API_KEY.
RESEND_API_KEY=
# Full-access key for Contacts API (bun run newsletter:sync). Required if RESEND_API_KEY is send-only.
RESEND_CONTACTS_API_KEY=
# Verified sender address for newsletter confirmation emails.
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# HMAC secret used to generate tokenized /newsletter/manage/* links.
NEWSLETTER_TOKEN_SECRET=
