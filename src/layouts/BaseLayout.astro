---
import RssLink from "../components/RssLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { palette } from "../config/palette";
import {
  absoluteUrl,
  getPageTitle,
  hasSocialLinks,
  resolveSocialPlacement,
  siteConfig,
  SocialPlacement,
} from "../config/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname,
  ogType = "website",
} = Astro.props;

const pageTitle = getPageTitle(title);
const canonicalUrl = absoluteUrl(canonicalPath);
const rssFeed = siteConfig.feeds?.[0] ?? null;
const showSocial = hasSocialLinks();
const socialPlacement = resolveSocialPlacement(siteConfig.socialPlacement);
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      siteConfig.feeds.map((feed) => (
        <link
          rel="alternate"
          type={feed.type}
          title={feed.title}
          href={absoluteUrl(feed.path)}
        />
      ))
    }

    <style is:global define:vars={palette}>
      /* stylelint-disable selector-class-pattern, no-descending-specificity -- BEM blocks */
      :root {
        color-scheme: dark;

        /** Centralized literals (see `palette["accent-soft"]`); used for mast + cards below. */
        --color-text: #f4f1ea;
        --color-accent: #e8d8b8;
        --color-bg: #faf6ee;

        --color-theme: var(--theme-green);
        --accent: var(--accent-mustard);
        --accent-additional: var(--additional-red);

        --accent-border: color-mix(in srgb, var(--accent) 38%, transparent);
        --accent-border-strong: color-mix(
          in srgb,
          var(--accent) 55%,
          transparent
        );
        --accent-bg-subtle: color-mix(in srgb, var(--accent) 12%, transparent);

        --text: var(--text-primary);
        --muted: var(--text-muted);
        --body-copy: var(--text-body);
        --meta: var(--text-meta);

        --border: rgb(255 255 255 / 7%);

        --panel: linear-gradient(
          145deg,
          var(--panel-a) 0%,
          var(--panel-b) 100%
        );

        --elev-shadow:
          0 2px 20px rgb(0 0 0 / 16%), inset 0 1px 0 rgb(255 255 255 / 5%);

        --radius-card: 1.35rem;
        --radius-pill: 0.35rem;

        --font-sans:
          system-ui, -apple-system, blinkmacsystemfont, "Segoe UI", roboto,
          oxygen, ubuntu, cantarell, sans-serif;
        --font-serif:
          ui-serif, georgia, cambria, "Times New Roman", times, serif;
        --font-mono:
          ui-monospace, sfmono-regular, menlo, monaco, consolas,
          "Liberation Mono", "Courier New", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-size: 106.25%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text);
        background: linear-gradient(
          165deg,
          var(--page-a) 0%,
          var(--page-b) 42%,
          var(--page-c) 100%
        );

        /* Same gradient as .site-mast__logo-wrap; fixed = viewport-sized so the chip matches. */
        background-attachment: fixed;
        line-height: 1.52;
      }

      /**
       * Bottom inset when fixed social bar (v4) is active — must match total block height in
       * `SocialLinks.astro` `.site-social--v4` (padding + icon row + safe-area).
       */
      body.body--social-fixed {
        --site-social-height: calc(
          0.55rem + 2.6rem + 0.55rem + env(safe-area-inset-bottom, 0px)
        );

        padding-bottom: var(--site-social-height);
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-serif);
        font-weight: 600;
      }

      main {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 6rem;
      }

      /* —— Olive mast —— */
      .site-mast {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.75rem 0 0;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-mast__brand {
        display: flex;
        align-items: center;
        gap: 1.15rem;
        text-decoration: none;
        color: inherit;
        min-width: 0;
      }

      .site-mast__logo-wrap {
        display: block;
        width: 4.75rem;
        height: 4.75rem;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 50%;
        background: linear-gradient(
          165deg,
          var(--page-a) 0%,
          var(--page-b) 42%,
          var(--page-c) 100%
        );
        background-attachment: fixed;
      }

      @keyframes site-mast-logo-spin {
        to {
          transform: rotate(360deg);
        }
      }

      .site-mast__logo {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        animation: site-mast-logo-spin 32s linear infinite;
      }

      @media (prefers-reduced-motion: reduce) {
        .site-mast__logo {
          animation: none;
        }
      }

      .site-mast__text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 4.75rem;
        max-width: min(36rem, 100%);
      }

      .site-mast__name {
        margin: 0 0 0.4rem;
        font-family: var(--font-sans);
        font-size: clamp(1.1rem, 2.45vw, 1.38rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1.1;
        color: var(--color-text);
      }

      .site-mast__desc {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.52;
        color: rgb(184 181 174 / 88%);
      }

      .site-mast__rss {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.82rem;
        color: rgb(201 168 106 / 78%);
        text-decoration: none;
        padding: 0.4rem 0.55rem;
        border-radius: 0.35rem;
        border: 1px solid rgb(255 255 255 / 8%);
        background: rgb(0 0 0 / 15%);
      }

      .site-mast__rss:hover {
        color: var(--color-accent);
        border-color: rgb(201 168 106 / 25%);
      }

      .site-mast__brand:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 4px;
        border-radius: 0.25rem;
      }

      .site-mast__rss:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .site-mast__tools {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      /* —— Index / tag post cards (Olive) —— */
      .post-feed {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      .post-card {
        padding: 1.35rem 1.45rem 1.2rem;
        border-radius: 1.35rem;
        border: 1px solid rgb(255 255 255 / 7%);
        background: linear-gradient(145deg, #3e443e, #363b36);
        box-shadow: var(--elev-shadow);
      }

      .post-card__title {
        margin: 0 0 0.65rem;
        font-family: var(--font-serif);
        font-size: clamp(1.28rem, 2.6vw, 1.62rem);
        font-weight: 600;
        line-height: 1.22;
      }

      .post-card__title a {
        color: inherit;
        text-decoration: none;
      }

      .post-card__title a:hover {
        color: var(--color-accent);
      }

      .post-card__excerpt {
        margin: 0 0 1.2rem;
        font-size: 1rem;
        line-height: 1.68;
        color: rgb(217 213 204 / 94%);
        display: -webkit-box;
        -webkit-line-clamp: 6;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .post-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        list-style: none;
        margin: 0 0 1rem;
        padding: 0;
      }

      .post-card__tags a {
        font-size: 0.76rem;
        font-weight: 500;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 0.15rem 0;
        border: none;
        border-radius: 0;
        color: rgb(148 154 148 / 92%);
        text-decoration: underline;
        text-decoration-color: rgb(130 136 130 / 48%);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.22em;
        background: none;
        transition:
          color 0.15s ease,
          text-decoration-color 0.15s ease;
      }

      .post-card__tags a:hover {
        color: rgb(200 206 198 / 96%);
        text-decoration-color: rgb(201 168 106 / 55%);
      }

      .post-card__tags a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      .post-card__bar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 0.65rem 1rem;
      }

      .post-card__actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
      }

      .post-card__view {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-bg);
        text-decoration: none;
        padding: 0.48rem 1.1rem;
        border-radius: 999px;
        border: none;
        background: var(--accent);
        box-shadow: none;
        transition:
          background 0.15s ease,
          color 0.15s ease;
      }

      .post-card__view:hover {
        color: #fffefb;
        background: color-mix(in srgb, var(--accent) 82%, #fff 18%);
      }

      .post-card__view:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .post-card__draft {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.35rem 0.55rem;
        border-radius: var(--radius-pill);
        color: #fde8e4;
        background: color-mix(
          in srgb,
          var(--accent-additional) 28%,
          transparent
        );
        border: 1px solid
          color-mix(in srgb, var(--accent-additional) 55%, transparent);
      }

      .post-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.45;
        color: rgb(148 154 148 / 72%);
      }

      .post-card__date time {
        margin-left: 0.18rem;
        font-variant-numeric: tabular-nums;
        color: inherit;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </head>
  <body
    class:list={[
      {
        "body--social-fixed":
          showSocial && socialPlacement === SocialPlacement.FIXED_BOTTOM,
      },
    ]}
  >
    <header>
      <div class="site-mast">
        <a class="site-mast__brand" href="/">
          <span class="site-mast__logo-wrap">
            <img
              class="site-mast__logo"
              src="/favicon.svg"
              alt=""
              width="76"
              height="76"
              decoding="async"
            />
          </span>
          <div class="site-mast__text">
            <p class="site-mast__name">{siteConfig.mastName}</p>
            <p class="site-mast__desc">{siteConfig.mastTagline}</p>
          </div>
        </a>
        {
          showSocial && socialPlacement === SocialPlacement.MAST_TOOLS ? (
            <div class="site-mast__tools">
              <SocialLinks variant={SocialPlacement.MAST_TOOLS} />
              {rssFeed && <RssLink path={rssFeed.path} type={rssFeed.type} />}
            </div>
          ) : (
            rssFeed && <RssLink path={rssFeed.path} type={rssFeed.type} />
          )
        }
      </div>
      {
        showSocial && socialPlacement === SocialPlacement.BELOW_MAST && (
          <SocialLinks variant={SocialPlacement.BELOW_MAST} />
        )
      }
      {
        showSocial && socialPlacement === SocialPlacement.HEADER_BOTTOM && (
          <SocialLinks variant={SocialPlacement.HEADER_BOTTOM} />
        )
      }
    </header>
    <slot />
    {
      showSocial && socialPlacement === SocialPlacement.AFTER_CONTENT && (
        <SocialLinks variant={SocialPlacement.AFTER_CONTENT} />
      )
    }
    {
      showSocial && socialPlacement === SocialPlacement.FIXED_BOTTOM && (
        <SocialLinks variant={SocialPlacement.FIXED_BOTTOM} />
      )
    }
  </body>
</html>
