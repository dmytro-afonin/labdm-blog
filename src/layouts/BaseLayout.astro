---
import RssLink from "../components/RssLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import { absoluteUrl, getPageTitle, siteConfig } from "../config/site";
import "../styles/color-scheme-themes.css";

interface Props {
  title?: string;
  description?: string;
  /**
   * Required so prerender never touches `Astro.url` / `Astro.request` (Astro warns
   * when `Astro.request.headers` is read during SSG — there is no real HTTP request).
   */
  canonicalPath: string;
  ogType?: "website" | "article";
  noIndex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  canonicalPath,
  ogType = "website",
  noIndex = false,
} = Astro.props;

const pageTitle = getPageTitle(title);
const canonicalUrl = absoluteUrl(canonicalPath);
const rssFeed = siteConfig.feeds?.[0] ?? null;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta
      name="theme-color"
      content="#ebe6dc"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#353a34"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      siteConfig.feeds.map((feed) => (
        <link
          rel="alternate"
          type={feed.type}
          title={feed.title}
          href={absoluteUrl(feed.path)}
        />
      ))
    }

    <style is:global>
      /* stylelint-disable selector-class-pattern, no-descending-specificity */

      :root {
        --font-serif: ui-serif, georgia, serif;
        --font-mono: ui-monospace, menlo, monospace;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        font-size: 106.25%;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        font:
          1rem/1.55 system-ui,
          sans-serif;
        color: var(--text);
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-serif);
        font-weight: 600;
      }

      a {
        color: var(--accent);
      }

      /* —— Layout: page width + main flow —— */
      .mast,
      main,
      .footer {
        width: min(56rem, calc(100% - 2rem));
        margin-inline: auto;
      }

      main {
        flex: 1;
        padding: 1rem 0 6rem;
        min-width: 0;
      }

      main > h1 {
        margin: 0 0 1rem;
        font-size: clamp(1.35rem, 3vw, 1.75rem);
      }

      main > p {
        margin: 0 0 1rem;
        max-width: 36rem;
        color: var(--muted);
        line-height: 1.65;
      }

      main > p > a {
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }

      /* —— Mast (header) —— */
      .mast {
        padding-top: 1.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
      }

      .mast__brand {
        display: flex;
        align-items: center;
        gap: 1.15rem;
        color: inherit;
        text-decoration: none;
        min-width: 0;
      }

      .mast__brand > div {
        text-align: left;
      }

      .mast__logo {
        width: 4.75rem;
        height: 4.75rem;
        flex-shrink: 0;
        border-radius: 50%;
        animation: spin 32s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .mast__logo {
          animation: none;
        }
      }

      .mast__name {
        margin: 0 0 0.4rem;
        font-size: clamp(1.1rem, 2.45vw, 1.38rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1.1;
      }

      .mast__tagline {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .mast__row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        max-width: 26rem;
      }

      .mast__rss {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        height: 2.35rem;
        padding: 0 0.85rem;
        border: 1px solid var(--rule);
        border-radius: 1.35rem;
        background: var(--surface);
        color: var(--meta);
        font-size: 0.82rem;
        text-decoration: none;
      }

      .mast__rss:hover {
        color: var(--accent);
      }

      .rss-icon {
        width: 1.05em;
        height: 1.05em;
      }

      /* —— Subscribe form —— */
      .subscribe {
        position: relative;
        flex: 1 1 auto;
        min-width: 0;
        max-width: 22rem;
        display: flex;
        height: 2.35rem;
        border: 1px solid var(--rule);
        border-radius: 1.35rem;
        background: var(--surface);
        overflow: hidden;
      }

      .subscribe__input {
        flex: 1;
        min-width: 0;
        border: 0;
        border-radius: 1.35rem 0 0 1.35rem;
        background: transparent;
        padding: 0 1rem;
        font: inherit;
        font-size: 0.85rem;
        color: var(--text);
        outline: 0;
      }

      .subscribe__input::placeholder {
        color: var(--meta);
      }

      .subscribe__btn {
        border: 0;
        border-left: 1px solid var(--rule);
        border-radius: 0 1.35rem 1.35rem 0;
        background: transparent;
        padding: 0 1rem;
        font: inherit;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
      }

      .subscribe__btn:hover {
        background: var(--rule);
        color: var(--accent);
      }

      /* `.subscribe` uses `overflow: hidden` for the rounded pill, which clips
       * the site-wide outer focus ring. Use an inset ring on the input + button
       * so it stays visible inside the clipped container. */
      .subscribe__input:focus-visible,
      .subscribe__btn:focus-visible {
        outline: 0;
        box-shadow: inset 0 0 0 2px var(--accent);
      }

      .subscribe__hp {
        position: absolute;
        left: -9999px;
        opacity: 0;
      }

      /* —— Footer —— */
      .footer {
        margin-top: clamp(2rem, 5vw, 3rem);
        padding-bottom: 2.5rem;
      }

      .social {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 1.25rem;
        font-size: 0.9rem;
      }

      .social a {
        text-decoration: none;
      }

      .social a:hover {
        text-decoration: underline;
      }

      /* —— One site-wide focus ring —— */
      :focus-visible {
        outline: none;
        box-shadow: 0 0 0 2px var(--accent);
      }

      a:focus-visible {
        border-radius: 0.18em;
      }

      /* —— Post feed (home + tag pages) ——
       * Mobile: single column stack (title → excerpt → meta → tags).
       * ≥48rem (medium): 2×2 grid — title+excerpt on the left, meta+tags on the right.
       */
      .post-feed {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .post-row {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 0.85rem 0;
        line-height: 1.4;
      }

      .post-row__title {
        margin: 0;
        font: 500 1.1rem/1.32 var(--font-serif);
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.5rem 0.7rem;
      }

      .post-row__title a {
        color: var(--text);
        text-decoration: none;
      }

      .post-row__title a:hover {
        color: var(--accent-soft);
      }

      .post-row__draft {
        font-size: 0.78em;
        color: var(--accent);
      }

      .post-excerpt {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.55;
      }

      @media (width >= 48rem) {
        .post-row {
          display: grid;
          grid-template-columns: minmax(8rem, 13rem) 1fr;
          grid-template-areas:
            "meta title"
            "tags excerpt";
          gap: 0.4rem 1.5rem;
          align-items: baseline;
        }

        .post-row__title {
          grid-area: title;
        }

        .post-excerpt {
          grid-area: excerpt;
        }

        .post-row__meta {
          grid-area: meta;
          justify-self: end;
        }

        .post-tags {
          grid-area: tags;
          justify-self: end;
        }
      }

      /* —— Shared monospace meta text (dates, crumbs, labels, tags) —— */
      .post-row__meta,
      .post-tags,
      .post-crumbs,
      .post-pagination__label {
        font-family: var(--font-mono);
        color: var(--meta);
      }

      .post-row__meta {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
      }

      .post-row__meta > span[aria-hidden] {
        opacity: 0.5;
      }

      .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 0.85rem;
        list-style: none;
        margin: 0;
        padding: 0;
        font-size: 0.74rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .post-tags a {
        color: inherit;
        text-decoration: none;
      }

      .post-tags a:hover {
        color: var(--accent-soft);
      }

      /* —— Single post —— */
      .post-header {
        margin-bottom: 2.25rem;
      }

      .post-crumbs {
        margin: 0 0 1.4rem;
        font-size: 0.78rem;
      }

      .post-crumbs__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.35rem 0.6rem;
      }

      .post-crumbs__item {
        display: inline-flex;
        align-items: baseline;
      }

      .post-crumbs__item:not(:last-child)::after {
        content: "/";
        margin-inline-start: 0.6rem;
        opacity: 0.4;
        pointer-events: none;
      }

      .post-crumbs a {
        color: var(--accent-soft);
        text-decoration: none;
      }

      .post-crumbs a:hover {
        text-decoration: underline;
      }

      .post-title {
        margin: 0 0 0.85rem;
        font: 500 clamp(1.85rem, 5.4vw, 2.55rem) / 1.06 var(--font-serif);
        letter-spacing: -0.014em;
        color: var(--text);
      }

      .post-lede {
        margin: 0 0 1.4rem;
        max-width: 38rem;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.6;
      }

      /* —— Prose: rendered markdown —— */
      .prose {
        font-size: 1.04rem;
        line-height: 1.78;
      }

      .prose a {
        color: var(--accent-soft);
        font-weight: 600;
        text-underline-offset: 0.18em;
      }

      .prose a:hover {
        color: var(--text);
      }

      .prose p,
      .prose ul,
      .prose ol,
      .prose blockquote,
      .prose pre {
        margin: 0 0 1.1rem;
      }

      .prose h2,
      .prose h3,
      .prose h4 {
        margin: 1.85rem 0 0.85rem;
        line-height: 1.22;
      }

      .prose code {
        font-family: var(--font-mono);
      }

      .prose pre {
        overflow-x: auto;
        padding: 1rem;
        border-radius: 0.55rem;
        background: var(--code-bg);
      }

      .prose blockquote {
        padding-left: 1rem;
        border-left: 2px solid var(--accent);
        color: var(--muted);
      }

      /* —— Pagination —— */
      .post-pagination {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem 1.5rem;
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
      }

      .post-pagination a {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        color: inherit;
        text-decoration: none;
      }

      .post-pagination__link--next {
        grid-column: 2;
        text-align: right;
      }

      .post-pagination__label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .post-pagination__title {
        font: 500 1rem/1.32 var(--font-serif);
        color: var(--accent-soft);
      }

      .post-pagination a:hover .post-pagination__title {
        text-decoration: underline;
      }

      @media (width <= 38rem) {
        .post-pagination {
          grid-template-columns: 1fr;
        }

        .post-pagination__link--next {
          grid-column: auto;
          text-align: left;
        }
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <header class="mast">
      <a class="mast__brand" href="/">
        <img
          class="mast__logo"
          src="/favicon.svg"
          alt=""
          width="76"
          height="76"
          decoding="async"
          fetchpriority="low"
        />
        <div>
          <p class="mast__name">{siteConfig.mastName}</p>
          <p class="mast__tagline">{siteConfig.mastTagline}</p>
        </div>
      </a>
      <div class="mast__row">
        <SubscribeForm />
        {rssFeed && <RssLink path={rssFeed.path} type={rssFeed.type} />}
      </div>
    </header>
    <slot />
    <footer class="footer">
      <SocialLinks />
    </footer>
  </body>
</html>
