---
import RssLink from "../components/RssLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import { COLOR_SCHEME_STORAGE_KEY } from "../config/theme";
import {
  absoluteUrl,
  getPageTitle,
  hasSocialLinks,
  siteConfig,
} from "../config/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname,
  ogType = "website",
} = Astro.props;

const pageTitle = getPageTitle(title);
const canonicalUrl = absoluteUrl(canonicalPath);
const rssFeed = siteConfig.feeds?.[0] ?? null;
const showSocial = hasSocialLinks();
---

<!doctype html>
<html lang={siteConfig.lang} data-color-scheme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <script is:inline define:vars={{ colorSchemeKey: COLOR_SCHEME_STORAGE_KEY }}
    >
      (function () {
        try {
          const raw = localStorage.getItem(colorSchemeKey);
          const pref =
            raw === "light" || raw === "dark" || raw === "system"
              ? raw
              : "system";
          document.documentElement.dataset.colorScheme = pref;
          const eff =
            pref === "light"
              ? "light"
              : pref === "dark"
                ? "dark"
                : window.matchMedia("(prefers-color-scheme: dark)").matches
                  ? "dark"
                  : "light";
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta)
            meta.setAttribute(
              "content",
              eff === "light" ? "#ebe6dc" : "#353a34",
            );
        } catch {
          document.documentElement.dataset.colorScheme = "system";
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      siteConfig.feeds.map((feed) => (
        <link
          rel="alternate"
          type={feed.type}
          title={feed.title}
          href={absoluteUrl(feed.path)}
        />
      ))
    }

    <style is:global>
      /*
       * Do not use `define:vars={palette}` here: Astro injects those as inline `style` on
       * `html` / descendants, which overrides `html[data-color-scheme]` from this sheet and
       * breaks light theme. Primitives from `src/config/palette.ts` live in `:root` below.
       */
      /* stylelint-disable selector-class-pattern, no-descending-specificity -- BEM blocks */
      :root {
        /* Static brand ingredients (see palette.ts); theme sets semantic tokens on `html`. */
        --theme-green: #353a34;
        --accent-mustard: #c9a86a;
        --additional-red: #a6756a;
        --terra-soft: #e8cfc8;
        --radius-code: 0.55rem;

        --radius-card: 1.35rem;
        --radius-pill: 0.35rem;

        /** Mast: theme switcher, social chips, RSS — shared size + corner radius (matches cards / post pagination). */
        --mast-tool-height: 2.35rem;
        --mast-tool-radius: var(--radius-card);

        --theme-shift-duration: 0.32s;

        --font-sans:
          system-ui, -apple-system, blinkmacsystemfont, "Segoe UI", roboto,
          oxygen, ubuntu, cantarell, sans-serif;
        --font-serif:
          ui-serif, georgia, cambria, "Times New Roman", times, serif;
        --font-mono:
          ui-monospace, sfmono-regular, menlo, monaco, consolas,
          "Liberation Mono", "Courier New", monospace;
      }

      /** Dark — explicit choice or system with dark OS (`data-color-scheme` on `<html>`). */
      html[data-color-scheme="dark"],
      html[data-color-scheme="system"] {
        color-scheme: dark;

        --color-text: #f4f1ea;
        --color-accent: #e8d8b8;
        --color-bg: #faf6ee;

        --color-theme: var(--theme-green);
        --accent: var(--accent-mustard);
        --accent-soft: #e8d8b8;
        --accent-additional: var(--additional-red);

        --accent-border: color-mix(in srgb, var(--accent) 38%, transparent);
        --accent-border-strong: color-mix(
          in srgb,
          var(--accent) 55%,
          transparent
        );
        --accent-bg-subtle: color-mix(in srgb, var(--accent) 12%, transparent);

        --text-primary: #ebe8e2;
        --text-muted: #b8b5ae;
        --text-body: #d9d5cc;
        --text-meta: #9a968e;

        --text: var(--text-primary);
        --muted: var(--text-muted);
        --body-copy: var(--text-body);
        --meta: var(--text-meta);

        --page-a: #353a34;
        --page-b: #2d322d;
        --page-c: #262a26;

        --panel-a: #3e443e;
        --panel-b: #363b36;

        --border: rgb(255 255 255 / 7%);

        --panel: linear-gradient(
          145deg,
          var(--panel-a) 0%,
          var(--panel-b) 100%
        );

        --elev-shadow:
          0 2px 20px rgb(0 0 0 / 16%), inset 0 1px 0 rgb(255 255 255 / 5%);

        --mast-desc: rgb(184 181 174 / 88%);

        --rss-fg: rgb(201 168 106 / 78%);
        --rss-border: rgb(255 255 255 / 8%);
        --rss-bg: rgb(0 0 0 / 15%);
        --rss-hover-border: rgb(201 168 106 / 25%);

        --post-card-a: #3e443e;
        --post-card-b: #363b36;

        --excerpt-fg: rgb(217 213 204 / 94%);

        --tag-fg: rgb(148 154 148 / 92%);
        --tag-decor: rgb(130 136 130 / 48%);
        --tag-hover-fg: rgb(200 206 198 / 96%);
        --tag-hover-decor: rgb(201 168 106 / 55%);

        --meta-fg: rgb(148 154 148 / 72%);

        --view-hover-fg: #fffefb;

        --post-card-view-fg: #faf6ee;
        --post-card-view-bg: var(--accent);
        --post-card-view-border: transparent;
        --post-card-view-hover-fg: #fffefb;
        --post-card-view-hover-bg: color-mix(
          in srgb,
          var(--accent) 82%,
          #fff 18%
        );

        --post-card-draft-fg: #fde8e4;
        --post-card-draft-bg: color-mix(
          in srgb,
          var(--accent-additional) 28%,
          transparent
        );
        --post-card-draft-border: color-mix(
          in srgb,
          var(--accent-additional) 55%,
          transparent
        );

        --code-bg: rgb(22 24 22 / 92%);

        --theme-switch-border: rgb(255 255 255 / 12%);
        --theme-switch-bg: rgb(0 0 0 / 12%);
        --theme-switch-fg: rgb(200 198 192 / 90%);
        --theme-switch-fg-hover: var(--color-accent);
        --theme-switch-hover-bg: rgb(255 255 255 / 6%);
        --theme-switch-active-fg: #f4f1ea;
        --theme-switch-active-bg: rgb(201 168 106 / 22%);

        --social-accent: rgb(201 168 106 / 78%);
        --social-line: rgb(255 255 255 / 8%);
        --social-surface: rgb(0 0 0 / 15%);
        --social-hover-fg: #e8d8b8;
        --social-hover-line: rgb(201 168 106 / 25%);
      }

      @media (prefers-color-scheme: light) {
        html[data-color-scheme="system"] {
          color-scheme: light;

          --theme-green: #4d5650;

          --color-text: #1e231e;
          --color-accent: #6b5420;
          --color-bg: #1a1d1a;

          --color-theme: var(--theme-green);
          --accent: #b8944a;
          --accent-soft: #7a5f28;
          --accent-additional: #8f5e52;
          --accent-border: color-mix(in srgb, var(--accent) 42%, transparent);
          --accent-border-strong: color-mix(
            in srgb,
            var(--accent) 58%,
            transparent
          );
          --accent-bg-subtle: color-mix(
            in srgb,
            var(--accent) 14%,
            transparent
          );

          --text-primary: #131813;
          --text-muted: #5a6058;
          --text-body: #2c322c;
          --text-meta: #656c64;

          --text: var(--text-primary);
          --muted: var(--text-muted);
          --body-copy: var(--text-body);
          --meta: var(--text-meta);

          --page-a: #ebe7dc;
          --page-b: #e4e0d4;
          --page-c: #dbd6cc;

          --panel-a: #fffcf7;
          --panel-b: #f0ebe3;

          --border: rgb(0 0 0 / 9%);

          --panel: linear-gradient(
            145deg,
            var(--panel-a) 0%,
            var(--panel-b) 100%
          );

          --elev-shadow:
            0 2px 18px rgb(0 0 0 / 8%), inset 0 1px 0 rgb(255 255 255 / 45%);

          --mast-desc: rgb(62 68 62 / 85%);

          --rss-fg: rgb(110 82 36 / 88%);
          --rss-border: rgb(0 0 0 / 10%);
          --rss-bg: rgb(255 255 255 / 72%);
          --rss-hover-border: rgb(140 110 50 / 35%);

          --post-card-a: #fefdfa;
          --post-card-b: #f3efe6;

          --excerpt-fg: rgb(38 44 38 / 92%);

          --tag-fg: rgb(72 78 72 / 92%);
          --tag-decor: rgb(100 108 100 / 45%);
          --tag-hover-fg: rgb(42 48 42 / 96%);
          --tag-hover-decor: rgb(140 110 50 / 50%);

          --meta-fg: rgb(88 94 88 / 82%);

          --view-hover-fg: #1a1c1a;

          --post-card-view-fg: #3a3328;
          --post-card-view-bg: color-mix(in srgb, var(--accent) 26%, #fff 74%);
          --post-card-view-border: color-mix(
            in srgb,
            var(--accent) 34%,
            #e8e2d8 66%
          );
          --post-card-view-hover-fg: #2a241c;
          --post-card-view-hover-bg: color-mix(
            in srgb,
            var(--accent) 34%,
            #fff 66%
          );

          --post-card-draft-fg: #6b3e3a;
          --post-card-draft-bg: color-mix(
            in srgb,
            var(--accent-additional) 12%,
            #fff 88%
          );
          --post-card-draft-border: color-mix(
            in srgb,
            var(--accent-additional) 34%,
            transparent
          );

          --code-bg: rgb(244 241 234 / 96%);

          --theme-switch-border: rgb(0 0 0 / 12%);
          --theme-switch-bg: rgb(255 255 255 / 55%);
          --theme-switch-fg: rgb(52 56 52 / 88%);
          --theme-switch-fg-hover: #4a3a12;
          --theme-switch-hover-bg: rgb(0 0 0 / 5%);
          --theme-switch-active-fg: #1e221a;
          --theme-switch-active-bg: rgb(201 168 106 / 28%);

          --social-accent: rgb(130 100 40 / 85%);
          --social-line: rgb(0 0 0 / 10%);
          --social-surface: rgb(255 255 255 / 65%);
          --social-hover-fg: #5c4818;
          --social-hover-line: rgb(140 110 50 / 38%);
        }
      }

      /** Light — explicit toggle. */
      html[data-color-scheme="light"] {
        color-scheme: light;

        --theme-green: #4d5650;

        --color-text: #1e231e;
        --color-accent: #6b5420;
        --color-bg: #1a1d1a;

        --color-theme: var(--theme-green);
        --accent: #b8944a;
        --accent-soft: #7a5f28;
        --accent-additional: #8f5e52;
        --accent-border: color-mix(in srgb, var(--accent) 42%, transparent);
        --accent-border-strong: color-mix(
          in srgb,
          var(--accent) 58%,
          transparent
        );
        --accent-bg-subtle: color-mix(in srgb, var(--accent) 14%, transparent);

        --text-primary: #131813;
        --text-muted: #5a6058;
        --text-body: #2c322c;
        --text-meta: #656c64;

        --text: var(--text-primary);
        --muted: var(--text-muted);
        --body-copy: var(--text-body);
        --meta: var(--text-meta);

        --page-a: #ebe7dc;
        --page-b: #e4e0d4;
        --page-c: #dbd6cc;

        --panel-a: #fffcf7;
        --panel-b: #f0ebe3;

        --border: rgb(0 0 0 / 9%);

        --panel: linear-gradient(
          145deg,
          var(--panel-a) 0%,
          var(--panel-b) 100%
        );

        --elev-shadow:
          0 2px 18px rgb(0 0 0 / 8%), inset 0 1px 0 rgb(255 255 255 / 45%);

        --mast-desc: rgb(62 68 62 / 85%);

        --rss-fg: rgb(110 82 36 / 88%);
        --rss-border: rgb(0 0 0 / 10%);
        --rss-bg: rgb(255 255 255 / 72%);
        --rss-hover-border: rgb(140 110 50 / 35%);

        --post-card-a: #fefdfa;
        --post-card-b: #f3efe6;

        --excerpt-fg: rgb(38 44 38 / 92%);

        --tag-fg: rgb(72 78 72 / 92%);
        --tag-decor: rgb(100 108 100 / 45%);
        --tag-hover-fg: rgb(42 48 42 / 96%);
        --tag-hover-decor: rgb(140 110 50 / 50%);

        --meta-fg: rgb(88 94 88 / 82%);

        --view-hover-fg: #1a1c1a;

        --post-card-view-fg: #3a3328;
        --post-card-view-bg: color-mix(in srgb, var(--accent) 26%, #fff 74%);
        --post-card-view-border: color-mix(
          in srgb,
          var(--accent) 34%,
          #e8e2d8 66%
        );
        --post-card-view-hover-fg: #2a241c;
        --post-card-view-hover-bg: color-mix(
          in srgb,
          var(--accent) 34%,
          #fff 66%
        );

        --post-card-draft-fg: #6b3e3a;
        --post-card-draft-bg: color-mix(
          in srgb,
          var(--accent-additional) 12%,
          #fff 88%
        );
        --post-card-draft-border: color-mix(
          in srgb,
          var(--accent-additional) 34%,
          transparent
        );

        --code-bg: rgb(244 241 234 / 96%);

        --theme-switch-border: rgb(0 0 0 / 12%);
        --theme-switch-bg: rgb(255 255 255 / 55%);
        --theme-switch-fg: rgb(52 56 52 / 88%);
        --theme-switch-fg-hover: #4a3a12;
        --theme-switch-hover-bg: rgb(0 0 0 / 5%);
        --theme-switch-active-fg: #1e221a;
        --theme-switch-active-bg: rgb(201 168 106 / 28%);

        --social-accent: rgb(130 100 40 / 85%);
        --social-line: rgb(0 0 0 / 10%);
        --social-surface: rgb(255 255 255 / 65%);
        --social-hover-fg: #5c4818;
        --social-hover-line: rgb(140 110 50 / 38%);
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-size: 106.25%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text);
        background: linear-gradient(
          165deg,
          var(--page-a) 0%,
          var(--page-b) 42%,
          var(--page-c) 100%
        );

        /* Same gradient as .site-mast__logo-wrap; fixed = viewport-sized so the chip matches. */
        background-attachment: fixed;
        line-height: 1.52;
      }

      @media (prefers-reduced-motion: no-preference) {
        body {
          transition:
            color var(--theme-shift-duration) cubic-bezier(0.33, 1, 0.68, 1),
            background var(--theme-shift-duration)
              cubic-bezier(0.33, 1, 0.68, 1);
        }

        /**
         * Theme tokens live on `html[data-color-scheme]`; animate how they flow into
         * foreground/background/border (not layout). Scoped to `html[data-color-scheme]`
         * so there is no cost before hydration.
         */
        html[data-color-scheme] body * {
          transition-property:
            color, background-color, background-image, border-color, box-shadow,
            fill, stroke, text-decoration-color, outline-color;
          transition-duration: var(--theme-shift-duration);
          transition-timing-function: cubic-bezier(0.33, 1, 0.68, 1);
        }
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-serif);
        font-weight: 600;
        color: var(--text-primary);
      }

      main {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 6rem;
      }

      /* —— Olive mast —— */
      .site-mast {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.75rem 0 0;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-mast__brand {
        display: flex;
        align-items: center;
        gap: 1.15rem;
        text-decoration: none;
        color: inherit;
        min-width: 0;
      }

      .site-mast__logo-wrap {
        display: block;
        width: 4.75rem;
        height: 4.75rem;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 50%;
        background: linear-gradient(
          165deg,
          var(--page-a) 0%,
          var(--page-b) 42%,
          var(--page-c) 100%
        );
        background-attachment: fixed;
      }

      @keyframes site-mast-logo-spin {
        to {
          transform: rotate(360deg);
        }
      }

      .site-mast__logo {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        animation: site-mast-logo-spin 32s linear infinite;
      }

      @media (prefers-reduced-motion: reduce) {
        .site-mast__logo {
          animation: none;
        }
      }

      .site-mast__text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 4.75rem;
        max-width: min(36rem, 100%);
      }

      .site-mast__name {
        margin: 0 0 0.4rem;
        font-family: var(--font-sans);
        font-size: clamp(1.1rem, 2.45vw, 1.38rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1.1;
        color: var(--color-text);
      }

      .site-mast__desc {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.52;
        color: var(--mast-desc);
      }

      .site-mast__rss {
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        height: var(--mast-tool-height);
        min-height: var(--mast-tool-height);
        padding: 0 0.65rem;
        font-size: 0.82rem;
        line-height: 1;
        color: var(--rss-fg);
        text-decoration: none;
        border-radius: var(--mast-tool-radius);
        border: 1px solid var(--rss-border);
        background: var(--rss-bg);
      }

      .site-mast__rss:hover {
        color: var(--color-accent);
        border-color: var(--rss-hover-border);
      }

      .site-mast__brand:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 4px;
        border-radius: 0.25rem;
      }

      .site-mast__rss:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .site-mast__tools {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .site-mast__tools > .theme-switcher,
      .site-mast__tools > .site-social,
      .site-mast__tools > .site-mast__rss {
        flex: 0 0 auto;
        align-self: center;
      }

      /* —— Index / tag post cards (Olive) —— */
      .post-feed {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      .post-card {
        padding: 1.35rem 1.45rem 1.2rem;
        border-radius: 1.35rem;
        border: 1px solid var(--border);
        background: linear-gradient(
          145deg,
          var(--post-card-a),
          var(--post-card-b)
        );
        box-shadow: var(--elev-shadow);
      }

      .post-card__title {
        margin: 0 0 0.65rem;
        font-family: var(--font-serif);
        font-size: clamp(1.28rem, 2.6vw, 1.62rem);
        font-weight: 600;
        line-height: 1.22;
        color: var(--text-primary);
      }

      .post-card__title a {
        color: var(--text-primary);
        text-decoration: none;
      }

      .post-card__title a:hover {
        color: var(--color-accent);
      }

      .post-card__excerpt {
        margin: 0 0 1.2rem;
        font-size: 1rem;
        line-height: 1.68;
        color: var(--excerpt-fg);
        display: -webkit-box;
        -webkit-line-clamp: 6;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .post-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        list-style: none;
        margin: 0 0 1rem;
        padding: 0;
      }

      .post-card__tags a {
        font-size: 0.76rem;
        font-weight: 500;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 0.15rem 0;
        border: none;
        border-radius: 0;
        color: var(--tag-fg);
        text-decoration: underline;
        text-decoration-color: var(--tag-decor);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.22em;
        background: none;
        transition:
          color 0.15s ease,
          text-decoration-color 0.15s ease;
      }

      .post-card__tags a:hover {
        color: var(--tag-hover-fg);
        text-decoration-color: var(--tag-hover-decor);
      }

      .post-card__tags a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      .post-card__bar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 0.65rem 1rem;
      }

      .post-card__actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
      }

      .post-card__view {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--post-card-view-fg);
        text-decoration: none;
        padding: 0.48rem 1.1rem;
        border-radius: 999px;
        border: 1px solid var(--post-card-view-border);
        background: var(--post-card-view-bg);
        box-shadow: none;
        transition:
          background 0.15s ease,
          color 0.15s ease,
          border-color 0.15s ease;
      }

      .post-card__view:hover {
        color: var(--post-card-view-hover-fg);
        background: var(--post-card-view-hover-bg);
      }

      .post-card__view:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .post-card__draft {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.35rem 0.55rem;
        border-radius: var(--radius-pill);
        color: var(--post-card-draft-fg);
        background: var(--post-card-draft-bg);
        border: 1px solid var(--post-card-draft-border);
      }

      .post-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.45;
        color: var(--meta-fg);
      }

      .post-card__date time {
        margin-left: 0.18rem;
        font-variant-numeric: tabular-nums;
        color: inherit;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-mast">
        <a class="site-mast__brand" href="/">
          <span class="site-mast__logo-wrap">
            <img
              class="site-mast__logo"
              src="/favicon.svg"
              alt=""
              width="76"
              height="76"
              decoding="async"
            />
          </span>
          <div class="site-mast__text">
            <p class="site-mast__name">{siteConfig.mastName}</p>
            <p class="site-mast__desc">{siteConfig.mastTagline}</p>
          </div>
        </a>
        <div class="site-mast__tools">
          <ThemeSwitcher />
          {showSocial && <SocialLinks />}
          {rssFeed && <RssLink path={rssFeed.path} type={rssFeed.type} />}
        </div>
      </div>
    </header>
    <slot />
  </body>
</html>
