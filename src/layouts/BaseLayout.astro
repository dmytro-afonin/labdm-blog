---
import RssLink from "../components/RssLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import { absoluteUrl, getPageTitle, siteConfig } from "../config/site";
import "../styles/color-scheme-themes.scss";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  noIndex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname,
  ogType = "website",
  noIndex = false,
} = Astro.props;

const pageTitle = getPageTitle(title);
const canonicalUrl = absoluteUrl(canonicalPath);
const rssFeed = siteConfig.feeds?.[0] ?? null;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta
      name="theme-color"
      content="#ebe6dc"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#353a34"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <!-- Preload + same URL on rel=icon and mast <img> so one fetch can satisfy both; see fetchpriority on the img. -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      siteConfig.feeds.map((feed) => (
        <link
          rel="alternate"
          type={feed.type}
          title={feed.title}
          href={absoluteUrl(feed.path)}
        />
      ))
    }

    <style is:global>
      /*
       * Do not use `define:vars={palette}` here: Astro injects those as inline `style` on
       * `html` / descendants, which can override theme tokens from `color-scheme-themes.scss`.
       * Primitives from `src/config/palette.ts` live in `:root` below.
       */
      /* stylelint-disable selector-class-pattern, no-descending-specificity -- BEM blocks */
      :root {
        /* Static brand ingredients (see palette.ts); theme sets semantic tokens on `html`. */
        --theme-green: #353a34;
        --accent-mustard: #c9a86a;
        --additional-red: #a6756a;
        --terra-soft: #e8cfc8;
        --radius-code: 0.55rem;

        --radius-card: 1.35rem;
        --radius-pill: 0.35rem;

        /** Mast: RSS chip — size + corner radius (matches cards / post pagination). */
        --mast-tool-height: 2.35rem;
        --mast-tool-radius: var(--radius-card);

        /** Keyboard focus ring thickness (see shared :focus-visible rules below). */
        --focus-ring-width: 2px;

        --theme-shift-duration: 0.32s;

        --font-sans:
          system-ui, -apple-system, blinkmacsystemfont, "Segoe UI", roboto,
          oxygen, ubuntu, cantarell, sans-serif;
        --font-serif:
          ui-serif, georgia, cambria, "Times New Roman", times, serif;
        --font-mono:
          ui-monospace, sfmono-regular, menlo, monaco, consolas,
          "Liberation Mono", "Courier New", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-size: 106.25%;
        overflow-x: hidden;

        /* Fills iOS safe areas behind notch / home indicator (pairs with viewport-fit=cover). */
        background-color: var(--page-a);
        min-height: 100%;
        min-height: 100dvh;
        min-height: -webkit-fill-available;
      }

      body {
        margin: 0;
        display: flex;
        flex-direction: column;

        /**
         * Full viewport height: `dvh` for modern browsers. Do not also set
         * `-webkit-fill-available` here — that duplicates `html` and can add
         * extra scroll / wrong height in iOS Safari when combined with `100dvh`.
         */
        min-height: 100%;
        min-height: 100dvh;
        font-family: var(--font-sans);
        color: var(--text);
        background-color: var(--page-a);
        line-height: 1.52;
      }

      body > header {
        flex-shrink: 0;
      }

      @media (prefers-reduced-motion: no-preference) {
        body {
          transition:
            color var(--theme-shift-duration) cubic-bezier(0.33, 1, 0.68, 1),
            background var(--theme-shift-duration)
              cubic-bezier(0.33, 1, 0.68, 1);
        }

        /**
         * Theme tokens on `html` from `color-scheme-themes.scss` (`prefers-color-scheme` only).
         */
        html body * {
          transition-property:
            color, background-color, background-image, border-color, box-shadow,
            fill, stroke, text-decoration-color, outline-color;
          transition-duration: var(--theme-shift-duration);
          transition-timing-function: cubic-bezier(0.33, 1, 0.68, 1);
        }
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-serif);
        font-weight: 600;
        color: var(--text-primary);
      }

      main {
        flex: 1 0 auto;
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1rem 0 6rem;
        min-width: 0;
      }

      /**
       * Simple text pages whose main content is a leading h1 + paragraphs (e.g. newsletter states).
       * Scoped to direct children so post/tag listings with back-links or sections are unaffected.
       */
      main > h1:first-child {
        margin: 0 0 1rem;
        font-size: clamp(1.35rem, 3vw, 1.75rem);
      }

      main > p {
        margin: 0 0 1rem;
        color: var(--body-copy);
        line-height: 1.65;
        max-width: 36rem;
      }

      main > p:last-child {
        margin-bottom: 0;
      }

      main > p > a {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }

      main > p > a:hover {
        color: var(--accent-soft);
      }

      /* —— Mast (header): two bands — top bar, then subscribe + meta —— */
      .site-mast {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.75rem 0 0;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0.85rem;
      }

      .site-mast__top {
        display: flex;
        flex-wrap: nowrap;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem 1.25rem;
        width: 100%;
        min-width: 0;
      }

      .site-mast__column {
        flex: 1 1 min(0, 100%);
        min-width: 0;
      }

      .site-mast__brand {
        display: flex;
        align-items: center;
        gap: 1.15rem;
        text-decoration: none;
        color: inherit;
        min-width: 0;
      }

      /** Subscribe + RSS: one row; RSS always beside the form (no breakpoint stacking). */
      .site-mast__subscribe-wrap {
        width: 100%;
        min-width: 0;
        padding-top: 0.35rem;
      }

      .site-mast__below {
        display: flex;
        flex-flow: row nowrap;
        align-items: center;
        gap: 0.5rem 0.75rem;
        width: 100%;
        min-width: 0;
      }

      .site-mast__below > .subscribe-form {
        flex: 1 1 auto;
        min-width: 0;
        max-width: 22rem;
      }

      .site-mast__below .site-mast__rss {
        flex: 0 0 auto;
      }

      .site-mast__logo-wrap {
        display: block;
        width: 4.75rem;
        height: 4.75rem;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 50%;
        background-color: var(--page-a);
      }

      @keyframes site-mast-logo-spin {
        to {
          transform: rotate(360deg);
        }
      }

      .site-mast__logo {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        animation: site-mast-logo-spin 32s linear infinite;
      }

      @media (prefers-reduced-motion: reduce) {
        .site-mast__logo {
          animation: none;
        }
      }

      .site-mast__text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 4.75rem;
        max-width: min(36rem, 100%);
      }

      .site-mast__name {
        margin: 0 0 0.4rem;
        font-family: var(--font-sans);
        font-size: clamp(1.1rem, 2.45vw, 1.38rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1.1;
        color: var(--color-text);
      }

      .site-mast__desc {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.52;
        color: var(--mast-desc);
      }

      .site-mast__rss {
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        height: var(--mast-tool-height);
        min-height: var(--mast-tool-height);
        padding: 0 0.65rem;
        font-size: 0.82rem;
        line-height: 1;
        color: var(--rss-fg);
        text-decoration: none;
        border-radius: var(--mast-tool-radius);
        border: 1px solid var(--rss-border);
        background: var(--rss-bg);
      }

      .site-mast__rss:hover {
        color: var(--color-accent);
        border-color: var(--rss-hover-border);
      }

      .site-footer {
        flex-shrink: 0;
        margin-top: clamp(2rem, 5vw, 3rem);
        padding: 0 0 2.5rem;
      }

      .site-footer__inner {
        width: min(56rem, calc(100% - 2rem));
        margin: 0 auto;
      }

      /**
       * Single accent focus ring site-wide. Prefer box-shadow over outline so the ring
       * follows border-radius (Subscribe pill, post titles, pills, etc.).
       */
      .site-mast__brand:focus-visible,
      .site-mast__rss:focus-visible,
      .post-card__title a:focus-visible,
      .post-card__tags a:focus-visible,
      .post-card__view:focus-visible,
      .site-footer-social__a:focus-visible,
      .back-link:focus-visible,
      .prose a:focus-visible {
        outline: none;
        box-shadow: 0 0 0 var(--focus-ring-width) var(--accent);
      }

      .site-mast__brand:focus-visible {
        border-radius: 0.25rem;
      }

      .post-card__title a:focus-visible,
      .prose a:focus-visible {
        border-radius: 0.12em;
      }

      .post-card__tags a:focus-visible {
        border-radius: 2px;
      }

      .back-link:focus-visible {
        border-radius: 0.15rem;
      }

      /* —— Index / tag post cards (Olive) —— */
      .post-feed {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      .post-card {
        padding: 1.35rem 1.45rem 1.2rem;
        border-radius: 1.35rem;
        border: 1px solid var(--border);
        background: linear-gradient(
          145deg,
          var(--post-card-a),
          var(--post-card-b)
        );
        box-shadow: var(--elev-shadow);
      }

      .post-card__title {
        margin: 0 0 0.65rem;
        font-family: var(--font-serif);
        font-size: clamp(1.28rem, 2.6vw, 1.62rem);
        font-weight: 600;
        line-height: 1.22;
        color: var(--text-primary);
      }

      .post-card__title a {
        color: var(--text-primary);
        text-decoration: none;
      }

      .post-card__title a:hover {
        color: var(--color-accent);
      }

      .post-card__excerpt {
        margin: 0 0 1.2rem;
        font-size: 1rem;
        line-height: 1.68;
        color: var(--excerpt-fg);
        display: -webkit-box;
        -webkit-line-clamp: 6;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .post-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        list-style: none;
        margin: 0 0 1rem;
        padding: 0;
      }

      .post-card__tags a {
        font-size: 0.76rem;
        font-weight: 500;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 0.15rem 0;
        border: none;
        border-radius: 0;
        color: var(--tag-fg);
        text-decoration: underline;
        text-decoration-color: var(--tag-decor);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.22em;
        background: none;
        transition:
          color 0.15s ease,
          text-decoration-color 0.15s ease;
      }

      .post-card__tags a:hover {
        color: var(--tag-hover-fg);
        text-decoration-color: var(--tag-hover-decor);
      }

      .post-card__bar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 0.65rem 1rem;
      }

      .post-card__actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
      }

      .post-card__view {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--post-card-view-fg);
        text-decoration: none;
        padding: 0.48rem 1.1rem;
        border-radius: 999px;
        border: 1px solid var(--post-card-view-border);
        background: var(--post-card-view-bg);
        box-shadow: none;
        transition:
          background 0.15s ease,
          color 0.15s ease,
          border-color 0.15s ease;
      }

      .post-card__view:hover {
        color: var(--post-card-view-hover-fg);
        background: var(--post-card-view-hover-bg);
      }

      .post-card__draft {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.35rem 0.55rem;
        border-radius: var(--radius-pill);
        color: var(--post-card-draft-fg);
        background: var(--post-card-draft-bg);
        border: 1px solid var(--post-card-draft-border);
      }

      .post-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.45;
        color: var(--meta-fg);
      }

      .post-card__date time {
        margin-left: 0.18rem;
        font-variant-numeric: tabular-nums;
        color: inherit;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-mast">
        <div class="site-mast__top">
          <div class="site-mast__column">
            <a class="site-mast__brand" href="/">
              <span class="site-mast__logo-wrap">
                <img
                  class="site-mast__logo"
                  src="/favicon.svg"
                  alt=""
                  width="76"
                  height="76"
                  decoding="async"
                  fetchpriority="low"
                />
              </span>
              <div class="site-mast__text">
                <p class="site-mast__name">{siteConfig.mastName}</p>
                <p class="site-mast__desc">{siteConfig.mastTagline}</p>
              </div>
            </a>
          </div>
        </div>
        <div class="site-mast__subscribe-wrap">
          <div class="site-mast__below">
            <SubscribeForm />
            {rssFeed && <RssLink path={rssFeed.path} type={rssFeed.type} />}
          </div>
        </div>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="site-footer__inner">
        <SocialLinks />
      </div>
    </footer>
  </body>
</html>
