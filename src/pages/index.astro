---
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisiblePosts } from "../utils/posts";

const posts = await getVisiblePosts();
---

<BaseLayout canonicalPath="/">
  <main>
    <section aria-labelledby="posts-heading">
      <h2 id="posts-heading" class="visually-hidden">Recent posts</h2>

      {
        posts.length === 0 ? (
          <p class="home-empty">
            No posts yet. Add a markdown file under{" "}
            <code>src/content/posts/</code> to publish the first article.
          </p>
        ) : (
          <ul class="post-feed">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </ul>
        )
      }
    </section>
  </main>
</BaseLayout>
