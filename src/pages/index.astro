---
import PostCardViewIcon from "../components/PostCardViewIcon.astro";
import PostDateRead from "../components/PostDateRead.astro";
import PostTags from "../components/PostTags.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPostUrl, getVisiblePosts, previewBlurb } from "../utils/posts";

const posts = await getVisiblePosts();
---

<BaseLayout canonicalPath="/">
  <main>
    <section aria-labelledby="posts-heading">
      <h2 id="posts-heading" class="visually-hidden">Recent posts</h2>

      {
        posts.length === 0 ? (
          <p class="home-empty">
            No posts yet. Add a markdown file under{" "}
            <code>src/content/posts/</code> to publish the first article.
          </p>
        ) : (
          <ul class="post-feed">
            {posts.map((post) => {
              const href = getPostUrl(post);
              const isDraft = post.data.draft;
              const tags = post.data.tags ?? [];
              const blurb = previewBlurb(post);

              return (
                <li>
                  <article class="post-card">
                    <h3 class="post-card__title">
                      <a href={href}>{post.data.title}</a>
                    </h3>
                    <p class="post-card__excerpt">{blurb}</p>
                    <PostTags
                      tags={tags}
                      ariaLabel={`Tags for ${post.data.title}`}
                    />
                    <footer class="post-card__bar">
                      <div class="post-card__actions">
                        <a
                          class="post-card__view"
                          href={href}
                          aria-label={`Read more: ${post.data.title}`}
                        >
                          Read more
                          <PostCardViewIcon />
                        </a>
                        {isDraft && <span class="post-card__draft">Draft</span>}
                      </div>
                      <PostDateRead post={post} />
                    </footer>
                  </article>
                </li>
              );
            })}
          </ul>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .home-empty {
    padding: 1.25rem 1.5rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius-card);
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .home-empty code {
    font-size: 0.88em;
  }
</style>
