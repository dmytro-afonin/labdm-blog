---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    {
      params: { state: "check-inbox" },
      props: {
        title: "Check your inbox",
        message:
          "We sent a confirmation link to that address. Open it to finish subscribing to new posts.",
      },
    },
    {
      params: { state: "already" },
      props: {
        title: "Already subscribed",
        message: "That email is already registered. No need to sign up again.",
      },
    },
    {
      params: { state: "invalid" },
      props: {
        title: "Check your email",
        message:
          "That address doesn't look valid. Go back and try again with a full email.",
      },
    },
    {
      params: { state: "error" },
      props: {
        title: "Something went wrong",
        message:
          "We couldn't save your subscription right now. Please try again in a moment.",
      },
    },
    {
      params: { state: "confirmed" },
      props: {
        title: "Subscription confirmed",
        message:
          "Your email is verified and you're now on the list for future posts.",
      },
    },
    {
      params: { state: "confirm-invalid" },
      props: {
        title: "Confirmation link invalid",
        message:
          "That confirmation link is invalid or no longer matches a pending subscriber record.",
      },
    },
    {
      params: { state: "confirm-expired" },
      props: {
        title: "Confirmation link expired",
        message:
          "That confirmation link has expired. Submit your email again and we'll send a fresh verification link.",
      },
    },
    {
      params: { state: "resubscribed" },
      props: {
        title: "Subscription restored",
        message:
          "You're back on the list. You'll start receiving emails again.",
      },
    },
    {
      params: { state: "unsubscribed" },
      props: {
        title: "Unsubscribed",
        message:
          "You have been removed from newsletter updates. If you change your mind, the same manage link can subscribe you again.",
      },
    },
    {
      params: { state: "manage-invalid" },
      props: {
        title: "Manage link expired",
        message:
          "That newsletter management link is invalid or no longer matches a subscriber record.",
      },
    },
  ];
}

interface Props {
  title: string;
  message: string;
}

const { title, message } = Astro.props;
---

<BaseLayout
  title={title}
  canonicalPath={`/newsletter/${Astro.params.state}`}
  noIndex
>
  <main>
    <h1>{title}</h1>
    <p>{message}</p>
    <p><a href="/">← Back to the blog</a></p>
  </main>
</BaseLayout>
