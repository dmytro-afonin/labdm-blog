---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    {
      params: { state: "thanks" },
      props: {
        title: "Subscribed",
        message:
          "Thanks — you're on the list. New posts will land in your inbox when they're published.",
      },
    },
    {
      params: { state: "already" },
      props: {
        title: "Already subscribed",
        message: "That email is already registered. No need to sign up again.",
      },
    },
    {
      params: { state: "invalid" },
      props: {
        title: "Check your email",
        message:
          "That address doesn't look valid. Go back and try again with a full email.",
      },
    },
    {
      params: { state: "error" },
      props: {
        title: "Something went wrong",
        message:
          "We couldn't save your subscription right now. Please try again in a moment.",
      },
    },
    {
      params: { state: "resubscribed" },
      props: {
        title: "Subscription restored",
        message:
          "You're back on the list. You'll start receiving emails again.",
      },
    },
    {
      params: { state: "unsubscribed" },
      props: {
        title: "Unsubscribed",
        message:
          "You have been removed from newsletter updates. If you change your mind, the same manage link can subscribe you again.",
      },
    },
    {
      params: { state: "manage-invalid" },
      props: {
        title: "Manage link expired",
        message:
          "That newsletter management link is invalid or no longer matches a subscriber record.",
      },
    },
  ];
}

interface Props {
  title: string;
  message: string;
}

const { title, message } = Astro.props;
---

<BaseLayout title={title} canonicalPath={`/newsletter/${Astro.params.state}`}>
  <main>
    <h1>{title}</h1>
    <p>{message}</p>
    <p><a href="/">← Back to the blog</a></p>
  </main>
</BaseLayout>
