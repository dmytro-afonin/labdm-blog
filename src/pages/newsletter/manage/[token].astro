---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getNewsletterManageView } from "../../../lib/newsletter";
import { isDatabaseConfigured } from "../../../lib/neon";

export const prerender = false;

const token = Astro.params.token ?? "";
const manageView =
  token && isDatabaseConfigured() ? await getNewsletterManageView(token) : null;
---

<BaseLayout
  title="Newsletter preferences"
  canonicalPath="/newsletter/manage"
  noIndex={true}
>
  <main>
    <h1>Newsletter preferences</h1>
    {
      manageView ? (
        <>
          <p>{manageView.message}</p>
          <form
            class="newsletter-manage"
            method="post"
            action="/api/newsletter/manage"
          >
            <input type="hidden" name="token" value={token} />
            <input type="hidden" name="action" value={manageView.action} />
            <button class="newsletter-manage__button" type="submit">
              {manageView.submitLabel}
            </button>
          </form>
        </>
      ) : (
        <>
          <p>
            This newsletter management link is invalid, expired, or unavailable
            because subscriber storage is not configured.
          </p>
          <p>
            <a href="/newsletter/manage-invalid">
              View the fallback status page
            </a>
          </p>
        </>
      )
    }
    <p><a href="/">← Back to the blog</a></p>
  </main>
</BaseLayout>

<style>
  .newsletter-manage {
    margin: 1.25rem 0 0;
  }

  .newsletter-manage__button {
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0.7rem 1.15rem;
    font: inherit;
    font-weight: 600;
    color: var(--page-a);
    background: var(--accent);
    cursor: pointer;
  }

  .newsletter-manage__button:hover {
    background: var(--accent-soft);
    border-color: var(--accent-soft);
  }

  .newsletter-manage__button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    background: var(--accent-soft);
    border-color: var(--accent-soft);
  }
</style>
