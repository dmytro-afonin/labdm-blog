---
import PostCardViewIcon from "../../components/PostCardViewIcon.astro";
import PostDateRead from "../../components/PostDateRead.astro";
import PostTags from "../../components/PostTags.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllTagSlugsFromPosts,
  getPostUrl,
  getPostsForTagSlug,
  getVisiblePosts,
  previewBlurb,
  slugifyTag,
  type BlogPost,
} from "../../utils/posts";

function formatTagLabelFromSlug(tagSlug: string) {
  return tagSlug
    .split("-")
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");
}

export async function getStaticPaths() {
  const allPosts = await getVisiblePosts();

  return getAllTagSlugsFromPosts(allPosts).map((tagSlug) => {
    const posts = getPostsForTagSlug(allPosts, tagSlug);

    return {
      params: { tag: tagSlug },
      props: {
        posts,
        tagSlug,
      },
    };
  });
}

interface Props {
  posts: BlogPost[];
  tagSlug: string;
}

const { posts, tagSlug } = Astro.props;
const tagLabels = [
  ...new Set(
    posts
      .flatMap((post) => post.data.tags)
      .filter((tag) => slugifyTag(tag) === tagSlug),
  ),
].sort((left, right) => left.localeCompare(right));
const tagLabel = tagLabels[0] ?? formatTagLabelFromSlug(tagSlug);
const pageTitle = `Posts tagged ${tagLabel}`;
const pageDescription = `Browse ${posts.length} published ${posts.length === 1 ? "post" : "posts"} tagged ${tagLabel}.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/tags/${tagSlug}/`}
>
  <main>
    <a class="back-link" href="/">All posts</a>

    <header class="tag-page">
      <p class="tag-page__eyebrow">Tagged</p>
      <h1 class="tag-page__title">{tagLabel}</h1>
      <p class="tag-page__summary">
        {posts.length} published {posts.length === 1 ? "post" : "posts"} with this
        label.
      </p>
    </header>

    <section aria-labelledby="posts-heading">
      <h2 id="posts-heading" class="visually-hidden">Posts</h2>
      <ul class="post-feed">
        {
          posts.map((post) => {
            const href = getPostUrl(post);
            const tags = post.data.tags ?? [];
            const blurb = previewBlurb(post);
            const isDraft = post.data.draft;

            return (
              <li>
                <article class="post-card">
                  <h3 class="post-card__title">
                    <a href={href}>{post.data.title}</a>
                  </h3>
                  <p class="post-card__excerpt">{blurb}</p>
                  <PostTags
                    tags={tags}
                    ariaLabel={`Tags for ${post.data.title}`}
                  />
                  <footer class="post-card__bar">
                    <div class="post-card__actions">
                      <a
                        class="post-card__view"
                        href={href}
                        aria-hidden="true"
                        tabindex="-1"
                      >
                        Read more
                        <PostCardViewIcon />
                      </a>
                      {isDraft && <span class="post-card__draft">Draft</span>}
                    </div>
                    <PostDateRead post={post} />
                  </footer>
                </article>
              </li>
            );
          })
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    margin-bottom: 1.25rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .back-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 0.15rem;
  }

  .tag-page {
    margin-bottom: 2rem;
  }

  .tag-page__eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(130 136 130 / 75%);
  }

  .tag-page__title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.85rem, 4.1vw, 2.65rem);
    line-height: 1.12;
  }

  .tag-page__summary {
    margin: 0;
    max-width: 40ch;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--muted);
  }
</style>
