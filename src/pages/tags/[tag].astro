---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getAllTagSlugsFromPosts,
  getPostUrl,
  getPostsForTagSlug,
  getReadingTimeLabel,
  getTagUrl,
  getVisiblePosts,
  slugifyTag,
  type BlogPost,
} from "../../utils/posts";

function formatTagLabelFromSlug(tagSlug: string) {
  return tagSlug
    .split("-")
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");
}

export async function getStaticPaths() {
  const allPosts = await getVisiblePosts();

  return getAllTagSlugsFromPosts(allPosts).map((tagSlug) => {
    const posts = getPostsForTagSlug(allPosts, tagSlug);

    return {
      params: { tag: tagSlug },
      props: {
        posts,
        tagSlug,
      },
    };
  });
}

interface Props {
  posts: BlogPost[];
  tagSlug: string;
}

const { posts, tagSlug } = Astro.props;
const tagLabels = [
  ...new Set(
    posts
      .flatMap((post) => post.data.tags)
      .filter((tag) => slugifyTag(tag) === tagSlug),
  ),
].sort((left, right) => left.localeCompare(right));
const tagLabel = tagLabels[0] ?? formatTagLabelFromSlug(tagSlug);
const pageTitle = `Posts tagged ${tagLabel}`;
const pageDescription = `Browse ${posts.length} published ${posts.length === 1 ? "post" : "posts"} tagged ${tagLabel}.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/tags/${tagSlug}/`}
>
  <main>
    <a class="back-link" href="/">All posts</a>

    <section class="hero">
      <div class="pill">Tag archive</div>
      <h1>{tagLabel}</h1>
      <p>
        {posts.length} published {posts.length === 1 ? "post" : "posts"} tagged
        {" "}
        <span class="tag-highlight">{tagLabel}</span>.
      </p>
    </section>

    <section aria-labelledby="posts-heading">
      <div class="section-heading">
        <h2 id="posts-heading">Posts</h2>
      </div>

      <ol class="post-list">
        {
          posts.map((post) => {
            const href = getPostUrl(post);
            const tags = post.data.tags ?? [];

            return (
              <li>
                <article class="card">
                  <div class="meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatPostDate(post.data.pubDate)}
                    </time>
                    <span>{getReadingTimeLabel(post)}</span>
                  </div>

                  <h3>
                    <a href={href}>{post.data.title}</a>
                  </h3>

                  <p>{post.data.excerpt ?? post.data.description}</p>

                  {tags.length > 0 && (
                    <ul
                      class="tag-list"
                      aria-label={`Tags for ${post.data.title}`}
                    >
                      {tags.map((tag) => (
                        <li>
                          <a href={getTagUrl(tag)}>{tag}</a>
                        </li>
                      ))}
                    </ul>
                  )}

                  <a class="read-more" href={href}>
                    Read post
                  </a>
                </article>
              </li>
            );
          })
        }
      </ol>
    </section>
  </main>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    margin-bottom: 1.5rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .back-link:focus-visible {
    text-decoration: underline;
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .hero {
    margin-bottom: 2.5rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid rgb(56 189 248 / 35%);
    border-radius: 999px;
    color: var(--accent);
    font-size: 0.95rem;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    line-height: 1.02;
  }

  .hero p {
    max-width: 44rem;
    margin: 0 0 1.5rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .tag-highlight {
    color: var(--accent);
  }

  .card p {
    margin: 0 0 1.5rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--panel);
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 80px rgb(15 23 42 / 20%);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.75rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.4rem, 4vw, 1.8rem);
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }

  .tag-list li {
    display: flex;
  }

  .tag-list a {
    padding: 0.35rem 0.8rem;
    border: 1px solid rgb(56 189 248 / 35%);
    border-radius: 999px;
    color: var(--accent);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  h3 a:focus-visible {
    color: var(--accent);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .tag-list a:hover,
  .tag-list a:focus-visible {
    border-color: rgb(56 189 248 / 55%);
    background: rgb(56 189 248 / 10%);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .read-more:hover {
    text-decoration: underline;
  }

  .read-more:focus-visible {
    text-decoration: underline;
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
