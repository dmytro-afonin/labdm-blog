---
import Crumbs from "../../components/Crumbs.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllTagSlugsFromPosts,
  getPostsForTagSlug,
  getVisiblePosts,
  slugifyTag,
  type BlogPost,
} from "../../utils/posts";

function formatTagLabelFromSlug(tagSlug: string) {
  return tagSlug
    .split("-")
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");
}

export async function getStaticPaths() {
  const allPosts = await getVisiblePosts();

  return getAllTagSlugsFromPosts(allPosts).map((tagSlug) => {
    const posts = getPostsForTagSlug(allPosts, tagSlug);

    return {
      params: { tag: tagSlug },
      props: {
        posts,
        tagSlug,
      },
    };
  });
}

interface Props {
  posts: BlogPost[];
  tagSlug: string;
}

const { posts, tagSlug } = Astro.props;
const tagLabels = [
  ...new Set(
    posts
      .flatMap((post) => post.data.tags)
      .filter((tag) => slugifyTag(tag) === tagSlug),
  ),
].sort((left, right) => left.localeCompare(right));
const tagLabel = tagLabels[0] ?? formatTagLabelFromSlug(tagSlug);
const postsLabel = `${posts.length} ${posts.length === 1 ? "post" : "posts"}`;
const pageTitle = `Posts tagged ${tagLabel}`;
const pageDescription = `Browse ${postsLabel} tagged ${tagLabel}.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/tags/${tagSlug}/`}
>
  <main>
    <h1 class="visually-hidden">{pageTitle}</h1>
    <Crumbs>
      <li class="post-crumbs__item">
        <span>Tagged: {tagLabel}</span>
      </li>
      <li class="post-crumbs__item">
        <span>{postsLabel}</span>
      </li>
    </Crumbs>

    <ul class="post-feed">
      {posts.map((post) => <PostCard post={post} />)}
    </ul>
  </main>
</BaseLayout>
