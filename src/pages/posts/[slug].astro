---
import { render } from "astro:content";

import Crumbs from "../../components/Crumbs.astro";
import PostTags from "../../components/PostTags.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPostDateQuiet,
  getPostUrl,
  getReadingTimeLabel,
  getVisiblePosts,
  type BlogPost,
} from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getVisiblePosts();

  return posts.map((post, i) => {
    const newerPost = i > 0 ? (posts.at(i - 1) ?? null) : null;
    const olderPost = i < posts.length - 1 ? (posts.at(i + 1) ?? null) : null;

    return {
      params: { slug: post.id },
      props: { post, newerPost, olderPost },
    };
  });
}

interface Props {
  post: BlogPost;
  newerPost: BlogPost | null;
  olderPost: BlogPost | null;
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={getPostUrl(post)}
  ogType="article"
>
  <main>
    <article class="post">
      <header class="post-header">
        <Crumbs>
          <li class="post-crumbs__item">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatPostDateQuiet(post.data.pubDate)}
            </time>
          </li>
          <li class="post-crumbs__item">
            <span>{getReadingTimeLabel(post)}</span>
          </li>
          {
            post.data.updatedDate && (
              <li class="post-crumbs__item">
                <span>
                  Updated{" "}
                  <time datetime={post.data.updatedDate.toISOString()}>
                    {formatPostDateQuiet(post.data.updatedDate)}
                  </time>
                </span>
              </li>
            )
          }
        </Crumbs>
        <h1 class="post-title">{post.data.title}</h1>
        {
          post.data.description && (
            <p class="post-lede">{post.data.description}</p>
          )
        }
        <PostTags tags={post.data.tags} ariaLabel="Post tags" />
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    {
      (newerPost || olderPost) && (
        <nav class="post-pagination" aria-label="Adjacent posts">
          {newerPost && (
            <a
              class="post-pagination__link post-pagination__link--prev"
              href={getPostUrl(newerPost)}
            >
              <span class="post-pagination__label">← Newer</span>
              <span class="post-pagination__title">{newerPost.data.title}</span>
            </a>
          )}
          {olderPost && (
            <a
              class="post-pagination__link post-pagination__link--next"
              href={getPostUrl(olderPost)}
            >
              <span class="post-pagination__label">Older →</span>
              <span class="post-pagination__title">{olderPost.data.title}</span>
            </a>
          )}
        </nav>
      )
    }
  </main>
</BaseLayout>
