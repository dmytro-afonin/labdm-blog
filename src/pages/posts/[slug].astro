---
import { render } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPostUrl,
  getVisiblePosts,
  type BlogPost,
} from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getVisiblePosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);

const publishedLabel = formatPostDate(post.data.pubDate);
const updatedLabel = post.data.updatedDate
  ? formatPostDate(post.data.updatedDate)
  : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={getPostUrl(post)}
  ogType="article"
>
  <main>
    <a class="back-link" href="/">All posts</a>

    <article class="post">
      <header class="post-header">
        <p class="meta">
          Published <time datetime={post.data.pubDate.toISOString()}
            >{publishedLabel}</time
          >
        </p>

        {
          updatedLabel && post.data.updatedDate && (
            <p class="meta">
              Updated{" "}
              <time datetime={post.data.updatedDate.toISOString()}>
                {updatedLabel}
              </time>
            </p>
          )
        }

        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>

        {
          post.data.tags.length > 0 && (
            <ul class="tag-list" aria-label="Post tags">
              {post.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  .back-link {
    display: inline-flex;
    margin-bottom: 1.5rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .post {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    background: var(--panel);
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 80px rgb(15 23 42 / 25%);
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .meta {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.5rem, 7vw, 4.25rem);
    line-height: 1.02;
  }

  .description {
    margin: 0 0 1.25rem;
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-list li {
    padding: 0.35rem 0.8rem;
    border: 1px solid rgb(56 189 248 / 35%);
    border-radius: 999px;
    color: var(--accent);
  }

  .prose {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .prose a {
    color: var(--accent);
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote,
  .prose pre {
    margin: 0 0 1.25rem;
  }

  .prose h2,
  .prose h3,
  .prose h4 {
    margin: 2rem 0 1rem;
    line-height: 1.2;
  }

  .prose code {
    font-family:
      SFMono-Regular, ui-monospace, "Cascadia Code", "Source Code Pro", Menlo,
      Consolas, monospace;
  }

  .prose pre {
    overflow-x: auto;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: rgb(2 6 23 / 75%);
  }

  .prose blockquote {
    padding-left: 1rem;
    border-left: 3px solid rgb(56 189 248 / 35%);
    color: var(--muted);
  }
</style>
