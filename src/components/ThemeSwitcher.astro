---
import { COLOR_SCHEME_STORAGE_KEY } from "../config/theme";
---

<details class="theme-dd" data-theme-switcher>
  <summary class="theme-dd__trigger" aria-label="Theme">
    <span class="theme-dd__current" aria-hidden="true">◐</span>
  </summary>
  <div class="theme-dd__panel">
    <div class="theme-dd__list" role="listbox" aria-label="Theme">
      <button
        type="button"
        class="theme-dd__opt"
        role="option"
        data-scheme="light"
        aria-selected="false"
      >
        ☀
      </button>
      <button
        type="button"
        class="theme-dd__opt"
        role="option"
        data-scheme="dark"
        aria-selected="false"
      >
        ☾
      </button>
      <button
        type="button"
        class="theme-dd__opt"
        role="option"
        data-scheme="system"
        aria-selected="false"
      >
        ◐
      </button>
    </div>
  </div>
</details>

<script is:inline define:vars={{ storageKey: COLOR_SCHEME_STORAGE_KEY }}>
  (function () {
    const KEY = storageKey;
    const ICONS = { light: "☀", dark: "☾", system: "◐" };

    function readPreference() {
      try {
        const raw = localStorage.getItem(KEY);
        if (raw === "light" || raw === "dark" || raw === "system") return raw;
      } catch {
        /* localStorage unavailable */
      }
      return "system";
    }

    function effectiveScheme(pref) {
      if (pref === "light" || pref === "dark") return pref;
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    function applyDataColorScheme(pref) {
      if (pref === "light" || pref === "dark") {
        document.documentElement.setAttribute("data-color-scheme", pref);
      } else {
        document.documentElement.removeAttribute("data-color-scheme");
      }
    }

    function applyMeta(pref) {
      const meta = document.querySelector('meta[name="theme-color"]');
      if (!meta) return;
      meta.setAttribute(
        "content",
        effectiveScheme(pref) === "light" ? "#ebe6dc" : "#353a34",
      );
    }

    function closeDetails() {
      document.querySelectorAll("details.theme-dd[open]").forEach(function (d) {
        d.open = false;
      });
    }

    function syncGroup(root) {
      const pref = readPreference();
      root.querySelectorAll(".theme-dd__current").forEach(function (el) {
        el.textContent = ICONS[pref] || ICONS.system;
      });
      root.querySelectorAll("[data-scheme]").forEach(function (btn) {
        const v = btn.getAttribute("data-scheme");
        const active = v === pref;
        btn.setAttribute("aria-selected", active ? "true" : "false");
        btn.classList.toggle("theme-dd__opt--active", active);
      });
    }

    function bindRoot(root) {
      if (root.getAttribute("data-theme-bound") === "1") return;
      root.setAttribute("data-theme-bound", "1");
      syncGroup(root);
      root.querySelectorAll("[data-scheme]").forEach(function (btn) {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          const v = btn.getAttribute("data-scheme");
          if (v !== "light" && v !== "dark" && v !== "system") return;
          try {
            localStorage.setItem(KEY, v);
          } catch {
            /* quota / private mode */
          }
          applyDataColorScheme(v);
          applyMeta(v);
          document.querySelectorAll("[data-theme-switcher]").forEach(syncGroup);
          closeDetails();
        });
      });
    }

    function bindGlobalsOnce() {
      if (window.__labdmThemeGlobals) return;
      window.__labdmThemeGlobals = 1;

      document.addEventListener("click", function (e) {
        const t = e.target;
        if (!(t instanceof Node)) return;
        document
          .querySelectorAll("details.theme-dd[open]")
          .forEach(function (d) {
            if (!d.contains(t)) d.open = false;
          });
      });

      document.addEventListener("keydown", function (e) {
        if (e.key !== "Escape") return;
        closeDetails();
      });

      window.addEventListener("storage", function (e) {
        if (e.key !== KEY || e.newValue == null) return;
        if (
          e.newValue !== "light" &&
          e.newValue !== "dark" &&
          e.newValue !== "system"
        )
          return;
        applyDataColorScheme(e.newValue);
        applyMeta(e.newValue);
        document.querySelectorAll("[data-theme-switcher]").forEach(syncGroup);
      });

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", function () {
          if (readPreference() !== "system") return;
          applyMeta("system");
        });
    }

    document.querySelectorAll("[data-theme-switcher]").forEach(bindRoot);
    bindGlobalsOnce();
  })();
</script>

<style is:global>
  /* Pill control: closed = icon + hover ring; open = options + trigger in one chip. */
  .theme-dd {
    box-sizing: border-box;
    position: relative;
    display: inline-block;
    height: var(--mast-tool-height);
    border-radius: 999px;
    vertical-align: middle;
  }

  .theme-dd > summary.theme-dd__trigger {
    list-style: none;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    height: var(--mast-tool-height);
    min-height: var(--mast-tool-height);
    min-width: var(--mast-tool-height);
    padding: 0 0.42rem;
    font: inherit;
    line-height: 1;
    color: var(--theme-switch-fg);
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .theme-dd > summary.theme-dd__trigger::-webkit-details-marker {
    display: none;
  }

  .theme-dd__current {
    font-size: 1.05rem;
    line-height: 1;
    user-select: none;
  }

  .theme-dd:not([open]):hover > summary.theme-dd__trigger,
  .theme-dd:not([open]):focus-within > summary.theme-dd__trigger {
    border-color: var(--theme-switch-border);
    background: var(--theme-switch-hover-bg);
    color: var(--theme-switch-fg-hover);
  }

  .theme-dd[open] {
    display: inline-flex;
    flex-direction: row-reverse;
    align-items: stretch;
    justify-content: flex-start;
    gap: 0.12rem;
    height: var(--mast-tool-height);
    min-height: var(--mast-tool-height);
    max-height: var(--mast-tool-height);
    padding: 0 0 0 0.14rem;
    border: none;
    background: transparent;
    box-shadow: 0 0 0 1px var(--theme-switch-border);
    min-width: var(--mast-tool-height);
  }

  .theme-dd[open]:hover {
    box-shadow: 0 0 0 1px var(--rss-hover-border);
  }

  .theme-dd[open] > summary.theme-dd__trigger {
    flex: 0 0 auto;
    align-self: stretch;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    min-width: var(--mast-tool-height);
    height: var(--mast-tool-height);
    min-height: var(--mast-tool-height);
    max-height: var(--mast-tool-height);
    margin: 0;
    padding: 0 0.42rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--theme-switch-hover-bg);
    color: var(--theme-switch-fg-hover);
  }

  .theme-dd[open] .theme-dd__panel {
    position: static;
    z-index: auto;
    flex: 0 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    overflow: visible;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .theme-dd__list {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.12rem;
    height: 100%;
    background: transparent;
  }

  .theme-dd__opt {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.05rem;
    min-height: calc(var(--mast-tool-height) - 4px);
    margin: 0;
    padding: 0;
    font: inherit;
    font-size: 1.05rem;
    line-height: 1;
    color: var(--theme-switch-fg);
    background: transparent;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .theme-dd[open] .theme-dd__opt {
    color: var(--theme-switch-fg);
    background: transparent;
  }

  .theme-dd[open] .theme-dd__opt:hover,
  .theme-dd[open] .theme-dd__opt:focus-visible {
    color: var(--theme-switch-fg-hover);
    background: var(--theme-switch-hover-bg);
  }

  .theme-dd__opt--active {
    color: var(--theme-switch-active-fg);
    font-weight: 700;
  }

  /* Current scheme is shown on the trigger; hide the matching option in the strip. */
  .theme-dd .theme-dd__opt--active {
    display: none;
  }
</style>
