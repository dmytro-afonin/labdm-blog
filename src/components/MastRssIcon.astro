---
/**
 * Decorative RSS glyph (`aria-hidden`). Inherits `currentColor`. Sizing in BaseLayout.
 * Callers must provide accessible text (visible label and/or aria-label).
 */
---

<svg
  class="rss-icon"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  focusable="false"
  aria-hidden="true"
>
  <path
    d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"></path>
  <circle cx="5" cy="19" r="1.5" fill="currentColor"></circle>
</svg>
