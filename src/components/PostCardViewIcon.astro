---
/** Neutral “open” affordance — avoids emoji eyes / surveillance vibes. */
---

<span class="post-card__view-icon" aria-hidden="true">
  <svg
    class="post-card__view-chevron"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M9 6l6 6-6 6"
      stroke="currentColor"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</span>

<style>
  .post-card__view-icon {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  .post-card__view-chevron {
    display: block;
    width: 1.05em;
    height: 1.05em;
  }
</style>
