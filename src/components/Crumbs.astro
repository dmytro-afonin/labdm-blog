---
/**
 * Breadcrumb trail for the post page and tag page.
 * Renders “All posts” plus an `<ol>`; pass **`<li>`** children via the default slot.
 */
const homeHref = import.meta.env.BASE_URL;
---

<nav aria-label="Breadcrumb" class="post-crumbs">
  <ol class="post-crumbs__list">
    <li class="post-crumbs__item">
      <a href={homeHref}>All posts</a>
    </li>
    <slot />
  </ol>
</nav>
