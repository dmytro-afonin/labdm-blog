---
/**
 * Newsletter signup: POST to /api/subscribe (Neon `subscribers` table).
 * Styles live in BaseLayout.astro to keep the global bundle slim.
 */
---

<form
  class="subscribe"
  method="post"
  action="/api/subscribe"
  aria-label="Subscribe to email updates"
>
  <label class="visually-hidden" for="subscribe-email">Email address</label>
  <input
    class="subscribe__input"
    id="subscribe-email"
    name="email"
    type="email"
    autocomplete="email"
    placeholder="Type your email…"
    required
  />
  <button class="subscribe__btn" type="submit">Subscribe</button>
  <input
    class="subscribe__hp"
    type="text"
    name="company"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />
</form>
