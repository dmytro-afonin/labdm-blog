---
import PostTags from "./PostTags.astro";
import {
  formatPostDateQuiet,
  getPostUrl,
  getReadingTimeMinutes,
  previewBlurb,
  type BlogPost,
} from "../utils/posts";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const href = getPostUrl(post);
const blurb = previewBlurb(post);
const tags = post.data.tags ?? [];
---

<li class="post-row">
  <h3 class="post-row__title">
    <a href={href}>{post.data.title}</a>
    {post.data.draft && <small class="post-row__draft"> [draft]</small>}
  </h3>
  {blurb && <p class="post-excerpt">{blurb}</p>}
  <span class="post-row__meta">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatPostDateQuiet(post.data.pubDate)}
    </time>
    <span aria-hidden="true">·</span>
    <span>{getReadingTimeMinutes(post)} min</span>
  </span>
  <PostTags tags={tags} ariaLabel={`Tags for ${post.data.title}`} />
</li>
