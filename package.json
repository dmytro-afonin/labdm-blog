{
  "name": "labdm-blog",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "bun run lint:code && bun run lint:styles",
    "lint:code": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{astro,css}\" --allow-empty-input",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "smoke": "node scripts/smoke-preview.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.5.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vercel": "^50.35.0"
  },
  "dependencies": {
    "@astrojs/vercel": "^10.0.2",
    "astro": "^6.0.8"
  },
  "smoke": {
    "expectedSnippets": [
      "<title>Dmytro Afonin — labdm blog</title>",
      "Astro + Bun + Vercel"
    ]
  }
}
